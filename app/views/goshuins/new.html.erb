<div class="goshuin-form-page">
  <div class="goshuin-form-card">
    <h1 class="goshuin-form-title">御朱印を登録する</h1>
    <%= form_with model: @goshuin, local: true do |f| %>
      <div class="goshuin-form-group">
        <%= f.label :image, "御朱印の写真", class: "goshuin-form-label" %>
        <%= f.file_field :image, class: "goshuin-form-input" %>
      </div>

      <div class="goshuin-form-group">
        <%= f.label :place_name, "参拝した神社・お寺", class: "goshuin-form-label" %>
        <%= f.text_field :place_name, class: "goshuin-form-input" %>
      </div>

      <div class="goshuin-form-group">
        <%= f.label :visited_date, "参拝日", class: "goshuin-form-label" %>
        <%= f.date_field :visited_date, class: "goshuin-form-input" %>
      </div>

      <div class="goshuin-form-group">
        <%= f.label :category_id, "種類", class: "goshuin-form-label" %>
        <%= f.collection_select(:category_id, Category.all, :id, :name, {}, {class:"goshuin-form-select"}) %>
      </div>

      <div class="goshuin-form-group">
        <%= f.label :memo, "参拝メモ", class: "goshuin-form-label" %>
        <%= f.text_area :memo, class: "goshuin-form-textarea" %>
      </div>

      <div class="goshuin-form-group">
        <%= f.label :latitude, "参拝した場所", class: "goshuin-form-label" %>
        <p class="goshuin-map-help">地図をクリックして、参拝した場所を選択してください。</p>

        <%= f.hidden_field :latitude, id: "goshuin-latitude" %>
        <%= f.hidden_field :longitude, id: "goshuin-longitude" %>
        <div id="goshuin-map" class="goshuin-form-map"></div>
      </div>

      <div class="goshuin-form-submit">
        <%= f.submit "登録" %>
      </div>

    <% end %>
  </div>
</div>
