<div class="goshuin-index-page">
  <div class="goshuin-cover">
    <div class="goshuin-cover-info">
      <div class="goshuin-cover-user">
        <%= current_user.nickname %>さんの御朱印帳
      </div>

      <div class="goshuin-level-card level-<%= @level %>">
        <%# <div class="goshuin-level-title">現在の称号</div> %>
        <div class="goshuin-level-badge">
          Lv.<%= @level %> 
        </div>
        <div class="goshuin-level-name">
          <%= @level_name %>
        </div>

        <div class="goshuin-level-count">
          登録数：<%= @goshuin_count %>件
        </div>

        <div class="goshuin-next-level">
          <% if @next_level_count == "最大レベルです" %>
            <%= @next_level_count %>
          <% else %>
            次のレベルまであと<%= @next_level_count %>件
          <% end %>
        </div>
      </div>

      <%= link_to new_goshuin_path, class: "goshuin-register-link" do %>
        <span class="goshuin-register-button">御朱印を登録する</span>
      <% end %>
    </div>
  </div>

  <div class="goshuin-book-area">
    <% if @goshuins.any? %>
      <div class="goshuin-card-list">
        <% @goshuins.each do |goshuin| %>
          <%= link_to goshuin_path(goshuin), class: "goshuin-card-link" do %>
            <div class="goshuin-card">

              <% if goshuin.image.attached? %>
                <div class="goshuin-card-image">
                  <%= image_tag goshuin.image %>
                </div>
              <% else %>
                <div class="goshuin-card-no-image">
                  画像は登録されていません
                </div>
              <% end %>

              <div class="goshuin-place-name">
                <%= goshuin.place_name %>
              </div>

              <div class="goshuin-visited-date">
                参拝日：<%= goshuin.visited_date %>
              </div>

              <div class="goshuin-category">
                種類：<%= goshuin.category.name %>
              </div>

              <div class="goshuin-memo">
                <%= goshuin.memo %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="goshuin-empty-message">
        まだ御朱印が登録されていません
      </div>
    <% end %>
  </div>
</div>