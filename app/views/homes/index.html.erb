<div class="top-page">
  <div class="top-image">
    <%= image_tag "goshuin_quest_top.png", alt: "御朱印クエストのメインイラスト" %>

    <div class="top-text">
      <h1>御朱印クエスト</h1>
      <p>御朱印を集めて、旅の記録を残そう</p>
    </div>
  </div>

  <div class="top-actions">
    <% if user_signed_in? %>
      <%= link_to "御朱印一覧へ", "#" %>
      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete } %>
    <% else %>
      <%= link_to "新規登録", new_user_registration_path %>
      <%= link_to "ログイン", new_user_session_path %>
    <% end %>
  </div>

  <section class="feature-section">
    <h2>御朱印クエストでできること</h2>
    <ul>
      <li>御朱印を写真付きで記録できる</li>
      <li>参拝した場所をマップで確認できる</li>
      <li>登録数に応じてレベルアップできる</li>
    </ul>
  </section>
</div>
