<div class="map-page">
  <h1>御朱印マップ</h1>
  <div id="goshuin-all-map"></div>
  <% @goshuins.each do |goshuin| %>
  <div
    class="goshuin-map-data"
    data-latitude="<%= goshuin.latitude %>"
    data-longitude="<%= goshuin.longitude %>"
    data-place-name="<%= goshuin.place_name %>">
  </div>
  <% end %>
</div>